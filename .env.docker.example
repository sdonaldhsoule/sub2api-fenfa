# Docker 本地开发默认会覆盖下面这些值：
# DATABASE_URL
# WELFARE_FRONTEND_URL
# WELFARE_CORS_ORIGINS
# VITE_WELFARE_API_BASE
# VITE_WELFARE_APP_BASE

NODE_ENV=development
PORT=8787
WELFARE_JWT_SECRET=replace-with-strong-secret
WELFARE_JWT_EXPIRES_IN=12h
WELFARE_RATE_LIMIT_AUTH_WINDOW=10m
WELFARE_RATE_LIMIT_AUTH_LIMIT=20
WELFARE_RATE_LIMIT_CHECKIN_WINDOW=5m
WELFARE_RATE_LIMIT_CHECKIN_LIMIT=6
WELFARE_RATE_LIMIT_REDEEM_WINDOW=10m
WELFARE_RATE_LIMIT_REDEEM_LIMIT=10
WELFARE_RATE_LIMIT_ADMIN_MUTATION_WINDOW=1m
WELFARE_RATE_LIMIT_ADMIN_MUTATION_LIMIT=30

LINUXDO_CLIENT_ID=your-linuxdo-client-id
LINUXDO_CLIENT_SECRET=your-linuxdo-client-secret
LINUXDO_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
LINUXDO_TOKEN_URL=https://connect.linux.do/oauth2/token
LINUXDO_USERINFO_URL=https://connect.linux.do/api/user
LINUXDO_REDIRECT_URI=http://localhost:8787/api/auth/linuxdo/callback
LINUXDO_SCOPE=user

SUB2API_BASE_URL=https://your-sub2api.example.com
SUB2API_ADMIN_API_KEY=your-sub2api-admin-api-key
SUB2API_TIMEOUT_MS=10000
WELFARE_REVOKED_TOKEN_CLEANUP_INTERVAL=6h
WELFARE_MONITOR_SCAN_INTERVAL=5m
WELFARE_MONITOR_SNAPSHOT_INTERVAL=1h
WELFARE_MONITOR_OBSERVE_IP_THRESHOLD=4
WELFARE_MONITOR_BLOCK_IP_THRESHOLD=6
WELFARE_MONITOR_LOCK_DURATION=24h
WELFARE_MONITOR_LIVE_CACHE_TTL=30s
WELFARE_MONITOR_SNAPSHOT_RETENTION_DAYS=30

DEFAULT_CHECKIN_ENABLED=true
DEFAULT_DAILY_REWARD=10
DEFAULT_TIMEZONE=Asia/Shanghai

BOOTSTRAP_ADMIN_USER_IDS=
BOOTSTRAP_ADMIN_EMAILS=
BOOTSTRAP_ADMIN_SUBJECTS=

VITE_SUB2API_ADMIN_LOGIN_URL=
